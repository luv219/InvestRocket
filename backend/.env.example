# Neon PostgreSQL
DATABASE_URL=jdbc:postgresql://your-neon-hostname.neon.tech/your-db-name?sslmode=require
DATABASE_USERNAME=your_neon_username
DATABASE_PASSWORD=your_neon_password

# Application
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=replace_with_long_secure_secret_at_least_32_characters
JWT_EXPIRATION_MS=86400000
FRONTEND_URL=https://your-frontend.example.com

# Market data
FINANCIAL_API_PROVIDER=hybrid
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
# Backward-compatible Finnhub key when FINNHUB_API_KEY is unset
FINANCIAL_API_KEY=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=5
RATE_LIMIT_AUTH_REGISTER_PER_MINUTE=3
RATE_LIMIT_MARKET_QUOTE_PER_MINUTE=30
RATE_LIMIT_MARKET_SEARCH_PER_MINUTE=20
RATE_LIMIT_ORDERS_PER_MINUTE=20
RATE_LIMIT_WATCHLIST_PER_MINUTE=60
RATE_LIMIT_DEFAULT_PER_MINUTE=120
FINNHUB_RATE_LIMIT_PER_MINUTE=50
TWELVE_DATA_RATE_LIMIT_PER_MINUTE=8
