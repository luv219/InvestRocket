# Neon PostgreSQL
DATABASE_URL=jdbc:postgresql://your-neon-hostname.neon.tech/your-db-name?sslmode=require
DATABASE_USERNAME=your_neon_username
DATABASE_PASSWORD=your_neon_password

# Application
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=replace_with_long_secure_secret_at_least_32_characters
JWT_EXPIRATION_MS=86400000
FRONTEND_URL=https://your-frontend.example.com

# Market data
FINANCIAL_API_PROVIDER=hybrid
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
# Backward-compatible Finnhub key when FINNHUB_API_KEY is unset
FINANCIAL_API_KEY=
