# Neon PostgreSQL
DATABASE_URL=jdbc:postgresql://your-neon-hostname.neon.tech/your-db-name?sslmode=require
DATABASE_USERNAME=your_neon_username
DATABASE_PASSWORD=your_neon_password

# App Security
JWT_SECRET=replace_with_long_secure_secret_at_least_32_characters
JWT_EXPIRATION_MS=86400000

# App URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080

# Financial API
FINANCIAL_API_PROVIDER=mock
FINANCIAL_API_KEY=replace_with_your_api_key

# Pending Order Processor
PENDING_ORDER_PROCESSOR_ENABLED=true
PENDING_ORDER_PROCESSOR_INTERVAL_MS=30000

# Demo Live Price Stream
LIVE_PRICE_STREAM_ENABLED=true
LIVE_PRICE_STREAM_INTERVAL_MS=5000

# Portfolio Snapshot Scheduler
PORTFOLIO_SNAPSHOT_ENABLED=true
PORTFOLIO_SNAPSHOT_INTERVAL_MS=300000
